generator client {
  provider = "prisma-client-js"
  output   = "./generated/client_main"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_ACESSOS")
}

model t_acessos {
  id          Int      @id(map: "pk_t_acessos") @default(autoincrement())
  login       String?  @db.VarChar(60)
  senha       String?  @db.VarChar(15)
  nome        String?  @db.VarChar(30)
  funcao      String?  @db.VarChar(30)
  banco       String?  @db.VarChar(100)
  adm         String?  @db.Char(1)
  ativo       String?  @db.Char(1)
  con         Int?
  pwd         String?  @db.Char(1)
  cnpj        String?  @db.VarChar(18)
  ddd         String?  @db.VarChar(2)
  whatsapp    String?  @db.VarChar(10)
  createdat   DateTime @default(now()) @db.Timestamp(6)
  empresa     String?  @db.VarChar(100)
  logourl     String?  @db.VarChar(250)
  imagem_capa String?  @db.VarChar(250)
  subdominio  String?  @db.VarChar(60)
}
